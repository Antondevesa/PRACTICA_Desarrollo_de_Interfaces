<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="20.0" prefWidth="400.0" prefHeight="500.0"
      style="-fx-background-color: #f5f5f5;"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.practica_desarrollo_de_interfaces.controller.LoginController">

    <padding>
        <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
    </padding>

    <Label text="Iniciar Sesión">
        <font>
            <Font name="System Bold" size="24.0" />
        </font>
    </Label>

    <VBox spacing="5.0">
        <Label text="Usuario:" />
        <TextField fx:id="usernameField" promptText="Introduce tu usuario" />
    </VBox>

    <VBox spacing="5.0">
        <Label text="Contraseña:" />
        <PasswordField fx:id="passwordField" promptText="Introduce tu contraseña" />
    </VBox>

    <Button fx:id="loginButton" text="Entrar" onAction="#handleLogin"
            maxWidth="Infinity" />

    <Label fx:id="errorLabel" textFill="#e74c3c" wrapText="true" alignment="CENTER" />

    <Button text="Sign up" onAction="#goToRegister"/>

</VBox>