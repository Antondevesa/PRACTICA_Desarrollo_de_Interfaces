<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="15.0" prefWidth="400.0" prefHeight="550.0"
      style="-fx-background-color: #f5f5f5;"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.practica_desarrollo_de_interfaces.controller.RegisterController">

    <padding>
        <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
    </padding>

    <Label text="Registro de Usuario">
        <font>
            <Font name="System Bold" size="24.0" />
        </font>
    </Label>

    <VBox spacing="5.0">
        <Label text="Usuario:" />
        <TextField fx:id="usernameField" promptText="username" />
    </VBox>

    <VBox spacing="5.0">
        <Label text="Email:" />
        <TextField fx:id="emailField" promptText="email" />
    </VBox>

    <VBox spacing="5.0">
        <Label text="Contraseña:" />
        <PasswordField fx:id="passwordField" promptText="password" />
    </VBox>

    <VBox spacing="5.0">
        <Label text="Repetir Contraseña:" />
        <PasswordField fx:id="checkPasswordField" promptText="checkPassword" />
    </VBox>

    <Button text="Sign up" onAction="#handleRegister"
            maxWidth="Infinity" style="-fx-background-color: #34495e; -fx-text-fill: white; -fx-cursor: hand;" />

    <Label fx:id="errorLabel" textFill="#e74c3c" wrapText="true" alignment="CENTER" />

    <Button text="Volver al Login" onAction="#goToLogin"
            style="-fx-background-color: transparent; -fx-text-fill: #7f8c8d; -fx-cursor: hand; -fx-underline: true;" />

</VBox>