<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox fx:id="cardContainer" alignment="TOP_CENTER" spacing="10.0"
      prefWidth="250.0" maxWidth="250.0" minWidth="250.0"
      styleClass="card-view"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.practica_desarrollo_de_interfaces.controller.CardController">

    <padding>
        <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
    </padding>

    <children>
        <StackPane style="-fx-background-color: #f9f9f9; -fx-background-radius: 5;">
            <ImageView fx:id="carImage" fitHeight="130.0" fitWidth="220.0" pickOnBounds="true" preserveRatio="true" />
        </StackPane>

        <VBox spacing="5.0" alignment="TOP_LEFT">
            <children>
                <Label fx:id="typeLabel" style="-fx-font-weight: bold; -fx-font-size: 15px;" text="Tipo - Modelo" wrapText="true" />
                <Label fx:id="powerLabel" text="Potencia: 0 CV" style="-fx-text-fill: #555;" />
                <Label fx:id="dateLabel" text="Matriculación: 01/01/2024" style="-fx-text-fill: #555;" />

                <Label fx:id="communityFavLabel" text="⭐ FAVORITO COMUNIDAD" visible="false" managed="false"
                       style="-fx-text-fill: #f39c12; -fx-font-weight: bold; -fx-font-size: 10px;" />
            </children>
        </VBox>

        <Region VBox.vgrow="ALWAYS" /> <HBox alignment="CENTER_RIGHT" spacing="10.0">
        <children>
            <Button fx:id="favButton" onAction="#handleFavorite" minWidth="45.0" minHeight="35.0"
                    style="-fx-background-color: transparent; -fx-font-size: 20px; -fx-cursor: hand; -fx-padding: 0;" text="🤍" />

            <Region HBox.hgrow="ALWAYS" />

            <Button fx:id="updateButton" onAction="#handleUpdate" minWidth="40.0" minHeight="30.0"
                    style="-fx-background-color: #fab1a0; -fx-text-fill: white; -fx-cursor: hand; -fx-padding: 0;" text="✏" />
            <Button fx:id="deleteButton" onAction="#handleDelete" minWidth="40.0" minHeight="30.0"
                    style="-fx-background-color: #ff7675; -fx-text-fill: white; -fx-cursor: hand; -fx-padding: 0;" text="🗑" />
        </children>
    </HBox>
    </children>
</VBox>